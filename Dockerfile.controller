# Build stage
FROM golang:1.23-alpine AS builder

WORKDIR /app

# Install build dependencies
RUN apk add --no-cache git make

# Copy go.mod and go.sum for controller and the proto local module
COPY controller/go.mod controller/go.sum* ./controller/
COPY gen/go/go.mod ./gen/go/

# Download dependencies
WORKDIR /app/controller
RUN go mod download

# Copy the rest of the source code
WORKDIR /app
COPY controller/ ./controller/
COPY gen/go/ ./gen/go/

# Build the controller
WORKDIR /app/controller
# modernc.org/sqlite is pure Go, so CGO_DISABLED=1 is fine, or CGO_DISABLED=0 also fine. Assuming pure go so CGO_DISABLED=0
RUN CGO_ENABLED=0 GOOS=linux go build -o optipilot-controller .

# Final stage
FROM alpine:3.19

WORKDIR /app

RUN apk add --no-cache tzdata

COPY --from=builder /app/controller/optipilot-controller .
COPY --from=builder /app/controller/optipilot.yaml ./optipilot.yaml

# Expose HTTP dashboard and (optional) gRPC port if needed
EXPOSE 8080

ENTRYPOINT ["/app/optipilot-controller"]
