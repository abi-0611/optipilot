FROM python:3.11-slim AS builder
COPY --from=ghcr.io/astral-sh/uv:0.4.17 /uv /bin/uv

WORKDIR /app
COPY forecaster/pyproject.toml forecaster/uv.lock ./

ENV UV_COMPILE_BYTECODE=1 UV_LINK_MODE=copy

# Install dependencies using uv into a virtualenv
RUN uv sync --frozen --no-install-project

COPY forecaster/ .
COPY gen/python/ /app/gen/python/

RUN uv sync --frozen

FROM python:3.11-slim

WORKDIR /app

RUN apt-get update && \
    apt-get install -y --no-install-recommends libgomp1 && \
    rm -rf /var/lib/apt/lists/*

RUN useradd -m -s /bin/bash optipilot && \
    mkdir -p /data && \
    chown -R optipilot:optipilot /app /data

COPY --from=builder --chown=optipilot:optipilot /app/.venv /app/.venv
COPY --from=builder --chown=optipilot:optipilot /app/src/forecaster /app/src/forecaster
COPY --from=builder --chown=optipilot:optipilot /app/gen/python /app/gen/python
COPY --from=builder --chown=optipilot:optipilot /app/forecaster.yaml ./forecaster.yaml

USER optipilot
ENV PATH="/app/.venv/bin:$PATH"
ENV PYTHONPATH="/app/src:/app/gen/python"

EXPOSE 50051

ENTRYPOINT ["python", "-m", "forecaster"]
